# ==============================================================================
#                      SUPERVISOR APP - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to '.env' (or create 'backend/.env' and 'frontend/.env' as needed)
# and adjust the values for your local development setup.

# ------------------------------------------------------------------------------
# BACKEND CONFIGURATION
# ------------------------------------------------------------------------------
# Mode of the application (development, production)
NODE_ENV=development

# Port on which the backend server runs
PORT=5000

# Secret key used for signing JWT tokens
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Allowed frontend URL for CORS policy
FRONTEND_URL=http://localhost:3000

# Path to the SQLite database file
DB_PATH=./data/supervisor.db

# Serial Port configuration for LoRa communication
LORA_PORT=COM3
BAUD_RATE=9600


# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Vite requires the 'VITE_' prefix)
# ------------------------------------------------------------------------------
# Base API URL pointing to the backend
VITE_API_URL=http://localhost:5000/api

# WebSocket URL pointing to the backend
VITE_SOCKET_URL=http://localhost:5000
